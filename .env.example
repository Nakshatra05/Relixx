# Copy to `.env` in this folder OR in `frontend/` (both are loaded; `frontend/.env` wins on conflicts).
#
# Deploy (Foundry): set PRIVATE_KEY here, then `pnpm run deploy:env`.
# If you invoke `forge script` yourself, never insert `--` before `--private-key` / wallet flags: that forwards
# tokens into Solidity `run()` → "encode length mismatch". Use: forge script ... --broadcast --private-key 0x...
# PRIVATE_KEY=0x...
#
# Required: Para SDK only reads variables exposed to the browser — they MUST use the VITE_ prefix.
# `PARA_API_KEY` alone will NOT work. Restart `pnpm dev` after changing env files.

VITE_PARA_API_KEY=
# Optional: BETA (default) or PROD — must match the environment of your API key
# VITE_PARA_ENV=BETA

# Monad network (10143 = testnet, 143 = mainnet)
# Claim+swap quotes use Uniswap v3 on both (see README).
VITE_CHAIN_ID=10143
VITE_MONAD_RPC_URL=https://testnet-rpc.monad.xyz
# Optional override; defaults to testnet/mainnet explorer from VITE_CHAIN_ID
# VITE_MONAD_EXPLORER_URL=https://testnet.monadexplorer.com

# Deployed UniversalClaimLinks (Foundry: src/UniversalClaimLinks.sol)
VITE_UNIVERSAL_CLAIM_LINKS_ADDRESS=

VITE_TOKEN_USDC=0x754704Bc059F8C67012fEd69BC8A327a5aafb603

# Optional: start block for indexing ClaimCreated (default 0). Use deployment block if RPC times out on full history.
# VITE_CLAIMS_FROM_BLOCK=12345678

# Optional: Uniswap v3 — defaults match Uniswap Monad docs (mainnet 143). Testnet 10143 often has NO contracts at those addresses; USDC quotes need mainnet or future published testnet deploys.
# VITE_UNISWAP_V3_SWAP_ROUTER_10143=
# VITE_UNISWAP_V3_QUOTER_V2_10143=
# VITE_UNISWAP_V3_FACTORY_10143=
# Testnet WMON default in code: 0xFb8b0e77d0a2736C546d148e65842c67B001C541 — override if Monad publishes a new one
# VITE_UNISWAP_WMON_10143=
# VITE_UNISWAP_V3_SWAP_ROUTER_143=
# VITE_UNISWAP_V3_QUOTER_V2_143=
# VITE_UNISWAP_V3_FACTORY_143=
# VITE_UNISWAP_WMON_143=

# Optional: extra receiver token cards (beyond MON + USDC)
# VITE_CLAIM_TOKEN3_ADDRESS=
# VITE_CLAIM_TOKEN3_SYMBOL=DAK
# VITE_CLAIM_TOKEN3_DECIMALS=18
# VITE_CLAIM_TOKEN4_ADDRESS=
# VITE_CLAIM_TOKEN4_SYMBOL=YAKI
# VITE_CLAIM_TOKEN4_DECIMALS=18
